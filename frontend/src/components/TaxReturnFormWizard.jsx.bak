  // Sezione Deduzioni Canarie
  const renderCanaryDeductionsData = () => (
    <SectionWrapper sectionId="deducciones_canarias" config={SECTIONS_CONFIG.find(s => s.id === 'deducciones_canarias')}>
      <div className="space-y-6">
        <label className="flex items-center gap-2 cursor-pointer">
          <Checkbox
