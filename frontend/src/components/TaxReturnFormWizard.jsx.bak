// Categorie documenti
const DOC_CATEGORIES = [
  { value: 'certificado_fiscal', label: 'Certificato Fiscale' },
  { value: 'nomina', label: 'Busta Paga' },
  { value: 'bancario', label: 'Documento Bancario' },
  { value: 'contrato', label: 'Contratto' },
  { value: 'factura', label: 'Fattura' },
  { value: 'crypto', label: 'Report Crypto' },
  { value: 'catastral', label: 'Documento Catastale' },
  { value: 'discapacidad', label: 'Certificato Disabilità' },
  { value: 'familiar', label: 'Documento Familiare' },
  { value: 'otro', label: 'Altro' }
];

const TaxReturnFormWizard = ({ taxReturn: rawTaxReturn, token, user, onBack, onUpdate }) => {
  // Sanitizza i dati in ingresso
  const taxReturn = useMemo(() => {
    if (!rawTaxReturn) return null;
    try {
      return JSON.parse(JSON.stringify(rawTaxReturn));
    } catch (e) {
      console.error('Errore sanitizzazione taxReturn:', e);
      return rawTaxReturn || null;
    }
  }, [rawTaxReturn]);
  
  const [currentSection, setCurrentSection] = useState(0);
  const [saving, setSaving] = useState(false);
  const [loadingAuth, setLoadingAuth] = useState(true);
  
  // Stato delle sezioni (completata, non applicabile, in corso, non iniziata)
  const [sectionStatuses, setSectionStatuses] = useState(() => {
    if (!taxReturn) return {};
    const saved = taxReturn.section_statuses || {};
    const initial = {};
    SECTIONS_CONFIG.forEach(s => {
      if (!s.isSpecial) {
        initial[s.id] = saved[s.id] || SECTION_STATUS.NOT_STARTED;
      }
    });
    return initial;
  });
  
  // Form data per ogni sezione
  const [formData, setFormData] = useState(() => {
    if (!taxReturn) return {};
    return {
      datos_personales: taxReturn.datos_personales || {},
      situacion_familiar: taxReturn.situacion_familiar || {},
      rentas_trabajo: taxReturn.rentas_trabajo || {},
      autonomo: taxReturn.autonomo || {},
      inmuebles: taxReturn.inmuebles || { tiene_inmuebles: false },
      alquileres_cobrados: taxReturn.alquileres_cobrados || { tiene_alquileres: false },
      alquiler_pagado: taxReturn.alquiler_pagado || {},
      inversiones: taxReturn.inversiones || { tiene_inversiones: false },
      criptomonedas: taxReturn.criptomonedas || { tiene_criptomonedas: false },
      ganancias_patrimoniales: taxReturn.ganancias_patrimoniales || { tiene_ganancias_patrimoniales: false },
      deducciones: taxReturn.deducciones || {},
      deducciones_canarias: taxReturn.deducciones_canarias || {}
    };
  });
  
  const [documents, setDocuments] = useState(() => taxReturn?.documentos || []);
  const [uploading, setUploading] = useState(false);
  const [consentAccepted, setConsentAccepted] = useState(false);
  const [authText, setAuthText] = useState('');
  const [docCategory, setDocCategory] = useState('otro');  // For document upload section
  
  const signatureRef = useRef(null);
  
  // Determina se l'utente è un admin
  const isAdmin = ['commercialista', 'admin', 'super_admin'].includes(user?.role);
  const currentStatus = taxReturn?.stato || 'bozza';
  const isEditable = !isAdmin && ['bozza', 'documentazione_incompleta'].includes(currentStatus);
  
  const currentSectionConfig = SECTIONS_CONFIG[currentSection];

  // Carica testo autorizzazione
  useEffect(() => {
    if (!taxReturn?.id || !token) {
      setLoadingAuth(false);
      return;
    }
    
    const fetchAuthText = async () => {
      try {
        setLoadingAuth(true);
        const res = await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/authorization-text`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
          const data = await res.json();
          setAuthText(data.text);
        }
      } catch (error) {
        console.error('Errore caricamento testo autorizzazione:', error);
        // Non mostrare toast per questo errore - è secondario
      } finally {
        setLoadingAuth(false);
      }
    };
    fetchAuthText();
  }, [taxReturn?.id, token]);
  
  // Loading state se taxReturn non è disponibile
  if (!taxReturn || !taxReturn.id) {
    return (
      <div className="flex items-center justify-center min-h-[400px]">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-teal-600 mx-auto mb-4"></div>
          <p className="text-slate-600">Caricamento dichiarazione...</p>
        </div>
      </div>
    );
  }
  
  // Salva sezione (chiamato solo al cambio step)
  const saveSection = async (sectionId, data) => {
    if (!isEditable) return;
    
    setSaving(true);
    try {
      const res = await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/sections/${sectionId}`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      if (!res.ok) {
        const errorData = await res.json();
        throw new Error(errorData.detail || 'Errore salvataggio');
      }
      
      return true;
    } catch (error) {
      safeErrorToast(error);
      return false;
    } finally {
      setSaving(false);
    }
  };
  
  // Salva stati sezioni
  const saveSectionStatuses = async (statuses) => {
    try {
      await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/sections/section_statuses`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(statuses)
      });
    } catch (error) {
      console.error('Errore salvataggio stati sezioni:', error);
    }
  };
  
  // Gestione cambio campo (solo aggiorna lo stato locale, salva al cambio step)
  const handleFieldChange = (section, field, value) => {
    const newSectionData = {
      ...formData[section],
      [field]: value
    };
    
    setFormData(prev => ({
      ...prev,
      [section]: newSectionData
    }));
    
    // Aggiorna stato sezione a "in progress" se era "not started"
    if (sectionStatuses[section] === SECTION_STATUS.NOT_STARTED) {
      const newStatuses = { ...sectionStatuses, [section]: SECTION_STATUS.IN_PROGRESS };
      setSectionStatuses(newStatuses);
      // Non salviamo subito gli stati, verranno salvati al cambio step
    }
  };
  
  // Marca sezione come "Non Applicabile"
  const markSectionNotApplicable = async (sectionId) => {
    const newStatuses = { ...sectionStatuses, [sectionId]: SECTION_STATUS.NOT_APPLICABLE };
    setSectionStatuses(newStatuses);
    
    // Salva anche un flag nella sezione
    const newData = { ...formData[sectionId], _not_applicable: true };
    setFormData(prev => ({ ...prev, [sectionId]: newData }));
    
    await saveSection(sectionId, newData);
    await saveSectionStatuses(newStatuses);
    
    toast.success('Sezione segnata come non applicabile');
  };
  
  // Rimuovi "Non Applicabile"
  const unmarkSectionNotApplicable = (sectionId) => {
    const newStatuses = { ...sectionStatuses, [sectionId]: SECTION_STATUS.IN_PROGRESS };
    setSectionStatuses(newStatuses);
    
    const newData = { ...formData[sectionId], _not_applicable: false };
    setFormData(prev => ({ ...prev, [sectionId]: newData }));
    
    saveSectionStatuses(newStatuses);
  };
  
  // Valida sezione corrente
  const validateCurrentSection = () => {
    const config = currentSectionConfig;
    if (!config || config.skipValidation || config.isSpecial) return true;
    
    const sectionId = config.id;
    const status = sectionStatuses[sectionId];
    
    // Se marcata come non applicabile, è valida
    if (status === SECTION_STATUS.NOT_APPLICABLE) return true;
    
    // Se è già completata, è valida
    if (status === SECTION_STATUS.COMPLETED) return true;
    
    // Altrimenti verifica i campi required o il flag principale
    const data = formData[sectionId];
    
    // Per sezioni con campi obbligatori specifici (es. datos_personales)
    if (config.requiredFields && config.requiredFields.length > 0) {
      for (const field of config.requiredFields) {
        if (!data[field] || data[field] === '') {
          return false;
        }
      }
      return true;
    }
    
    // Per sezioni con toggle principale (es. "Ho percepito redditi...")
    // Devono aver risposto SI/NO esplicitamente
    const toggleFields = {
      'situacion_familiar': true, // sempre valida se confermata
      'rentas_trabajo': 'tiene_rentas_trabajo',
      'autonomo': 'es_autonomo',
      'inmuebles': 'tiene_inmuebles',
      'alquileres_cobrados': 'tiene_alquileres',
      'alquiler_pagado': 'paga_alquiler',
      'inversiones': 'tiene_inversiones',
      'criptomonedas': 'tiene_criptomonedas',
      'ganancias_patrimoniales': 'tiene_ganancias_patrimoniales',
      'deducciones': 'tiene_deducciones',
      'deducciones_canarias': 'tiene_deducciones_canarias'
    };
    
    // Se la sezione richiede una risposta esplicita
    if (toggleFields[sectionId] && toggleFields[sectionId] !== true) {
      // La sezione deve essere stata confermata (completata) o non applicabile
      // Per passare avanti, il cliente deve aver cliccato "Conferma e Prosegui"
      return status === SECTION_STATUS.COMPLETED;
    }
    
    return true;
  };
  
  // Conferma sezione e passa alla successiva
  const confirmAndProceed = async () => {
    const config = currentSectionConfig;
    if (!config) return;
    
    if (config.isSpecial) {
      // Per sezioni speciali (intro, documenti, riepilogo, autorizzazione) naviga direttamente
      goToNextSection();
      return;
    }
    
    const sectionId = config.id;
    const status = sectionStatuses[sectionId];
    
    // Se già non applicabile, vai avanti
    if (status === SECTION_STATUS.NOT_APPLICABLE) {
      goToNextSection();
      return;
    }
    
    // Valida campi obbligatori per dati personali
    if (config.requiredFields) {
      const data = formData[sectionId];
      const missingFields = config.requiredFields.filter(f => !data[f] || data[f] === '');
      
      if (missingFields.length > 0) {
        toast.error('Compila tutti i campi obbligatori prima di procedere');
        return;
      }
    }
    
    // Salva la sezione
    await saveSection(sectionId, formData[sectionId]);
    
    // Marca come completata
    const newStatuses = { ...sectionStatuses, [sectionId]: SECTION_STATUS.COMPLETED };
    setSectionStatuses(newStatuses);
    await saveSectionStatuses(newStatuses);
    
    toast.success('Sezione completata e salvata');
    goToNextSection();
  };
  
  // Navigazione
  const goToNextSection = () => {
    if (currentSection < SECTIONS_CONFIG.length - 1) {
      setCurrentSection(currentSection + 1);
    }
  };
  
  const goToPreviousSection = () => {
    if (currentSection > 0) {
      setCurrentSection(currentSection - 1);
    }
  };
  
  // Vai a sezione specifica (solo se precedenti sono complete)
  const goToSection = (index) => {
    // Controlla che tutte le sezioni precedenti siano complete
    for (let i = 1; i < index; i++) { // salta intro (0)
      const sec = SECTIONS_CONFIG[i];
      if (!sec.isSpecial && !sec.skipValidation) {
        const status = sectionStatuses[sec.id];
        if (status !== SECTION_STATUS.COMPLETED && status !== SECTION_STATUS.NOT_APPLICABLE) {
          toast.error(`Completa prima la sezione "${sec.name}"`);
          return;
        }
      }
    }
    setCurrentSection(index);
  };
  
  // Calcola progresso
  const calculateProgress = () => {
    const editableSections = SECTIONS_CONFIG.filter(s => !s.isSpecial && !s.skipValidation);
    const completed = editableSections.filter(s => 
      sectionStatuses[s.id] === SECTION_STATUS.COMPLETED || 
      sectionStatuses[s.id] === SECTION_STATUS.NOT_APPLICABLE
    ).length;
    return Math.round((completed / editableSections.length) * 100);
  };
  
  // Verifica se tutte le sezioni sono complete
  const allSectionsComplete = () => {
    return SECTIONS_CONFIG.every(s => {
      if (s.isSpecial || s.skipValidation) return true;
      const status = sectionStatuses[s.id];
      return status === SECTION_STATUS.COMPLETED || status === SECTION_STATUS.NOT_APPLICABLE;
    });
  };
  
  // Upload documento
  const handleUploadDocument = async (file, category, sectionId) => {
    setUploading(true);
    try {
      const formDataObj = new FormData();
      formDataObj.append('file', file);
      formDataObj.append('categoria', category);
      formDataObj.append('seccion', sectionId || 'generale');

      const res = await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/documents`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: formDataObj
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.detail || 'Errore upload');

      toast.success('Documento caricato');
      setDocuments(prev => [...prev, { id: data.document_id, nombre: file.name, categoria: category, seccion: sectionId }]);
    } catch (error) {
      safeErrorToast(error);
    } finally {
      setUploading(false);
    }
  };
  
  // Firma e invio
  const handleSign = async () => {
    if (!consentAccepted) {
      toast.error('Devi accettare il consenso per procedere');
      return;
    }
    
    if (signatureRef.current?.isEmpty()) {
      toast.error('Devi apporre la tua firma');
      return;
    }
    
    if (!allSectionsComplete()) {
      toast.error('Completa tutte le sezioni prima di firmare');
      return;
    }

    const signatureData = signatureRef.current.toDataURL('image/png');
    
    try {
      const formDataObj = new FormData();
      formDataObj.append('consent_accepted', 'true');
      formDataObj.append('signature_data', signatureData);

      const res = await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/sign`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` },
        body: formDataObj
      });
      
      const responseData = await res.json();
      
      if (!res.ok) {
        throw new Error(responseData.detail || 'Errore firma');
      }
      
      // Invia automaticamente la pratica dopo la firma
      const submitRes = await fetch(`${API_URL}/api/declarations/tax-returns/${taxReturn.id}/status`, {
        method: 'PUT',
        headers: { 'Authorization': `Bearer ${token}` },
        body: new URLSearchParams({ nuovo_stato: 'inviata' })
      });
      
      if (!submitRes.ok) {
        throw new Error('Errore invio pratica');
      }
      
      toast.success('Dichiarazione firmata e inviata con successo!');
      onBack();
    } catch (error) {
      safeErrorToast(error);
    }
  };

  const clearSignature = () => {
    signatureRef.current?.clear();
  };
  
  // Icona stato sezione
  const getSectionStatusIcon = (sectionId) => {
    const status = sectionStatuses[sectionId];
    switch (status) {
      case SECTION_STATUS.COMPLETED:
        return <CheckCircle2 className="w-5 h-5 text-green-600" />;
      case SECTION_STATUS.NOT_APPLICABLE:
        return <Ban className="w-5 h-5 text-slate-400" />;
      case SECTION_STATUS.IN_PROGRESS:
        return <Circle className="w-5 h-5 text-amber-500 fill-amber-200" />;
      default:
        return <Circle className="w-5 h-5 text-slate-300" />;
    }
  };
  
  // Colore stato sezione
  const getSectionStatusColor = (sectionId) => {
    const status = sectionStatuses[sectionId];
    switch (status) {
      case SECTION_STATUS.COMPLETED:
        return 'border-green-500 bg-green-50';
      case SECTION_STATUS.NOT_APPLICABLE:
        return 'border-slate-300 bg-slate-50';
      case SECTION_STATUS.IN_PROGRESS:
        return 'border-amber-500 bg-amber-50';
      default:
        return 'border-slate-200 bg-white';
    }
  };
  
  // Badge stato testuale
  const getSectionStatusBadge = (sectionId) => {
    const status = sectionStatuses[sectionId];
    switch (status) {
      case SECTION_STATUS.COMPLETED:
        return <Badge className="bg-green-100 text-green-700">Completata</Badge>;
      case SECTION_STATUS.NOT_APPLICABLE:
        return <Badge className="bg-slate-100 text-slate-600">Non applicabile</Badge>;
      case SECTION_STATUS.IN_PROGRESS:
        return <Badge className="bg-amber-100 text-amber-700">In compilazione</Badge>;
      default:
        return <Badge className="bg-slate-100 text-slate-500">Da compilare</Badge>;
    }
  };

  // === RENDER SECTIONS ===
  
  // Sezione Introduzione
  const renderIntro = () => (
    <div className="space-y-6">
      <div className="text-center mb-8">
        <div className="w-16 h-16 mx-auto bg-teal-100 rounded-full flex items-center justify-center mb-4">
          <CheckCircle className="w-8 h-8 text-teal-600" />
        </div>
        <h3 className="text-xl font-semibold text-slate-900 mb-2">
          Dichiarazione dei Redditi {taxReturn.anno_fiscale}
        </h3>
        <p className="text-slate-600">
          Benvenuto nella compilazione guidata della tua dichiarazione dei redditi.
        </p>
      </div>

      <Card className="bg-blue-50 border-blue-200">
        <CardContent className="p-5">
          <h4 className="font-semibold text-blue-800 mb-3 flex items-center gap-2">
            <AlertCircle className="w-5 h-5" />
            Come funziona
          </h4>
          <ol className="list-decimal list-inside text-sm text-blue-700 space-y-2">
            <li><strong>Compila ogni sezione</strong> - Ti guideremo passo dopo passo</li>
            <li><strong>Conferma esplicita</strong> - Se una sezione non ti riguarda, potrai dichiararlo esplicitamente</li>
            <li><strong>Salvataggio automatico</strong> - I tuoi dati vengono salvati automaticamente</li>
            <li><strong>Riepilogo finale</strong> - Potrai verificare tutto prima di firmare</li>
            <li><strong>Firma e invio</strong> - Completa con la tua firma digitale</li>
          </ol>
        </CardContent>
      </Card>

      <Card className="bg-amber-50 border-amber-200">
        <CardContent className="p-5">
          <h4 className="font-semibold text-amber-800 mb-2 flex items-center gap-2">
            <AlertTriangle className="w-5 h-5" />
            Importante
          </h4>
          <p className="text-sm text-amber-700">
            Non potrai saltare le sezioni. Devi completare o dichiarare "non applicabile" ogni sezione prima di passare alla successiva. Questo garantisce che la tua dichiarazione sia completa e accurata.
          </p>
        </CardContent>
      </Card>

      <div className="text-center pt-4">
        <Button 
          onClick={goToNextSection} 
          className="bg-teal-600 hover:bg-teal-700"
          size="lg"
        >
          Inizia la compilazione
          <ArrowRight className="w-5 h-5 ml-2" />
        </Button>
      </div>
    </div>
  );
  
  // Wrapper per sezione con opzione "Non Applicabile"
  const SectionWrapper = ({ children, sectionId, config }) => {
    const status = sectionStatuses[sectionId];
    const isNotApplicable = status === SECTION_STATUS.NOT_APPLICABLE;
    
    return (
      <div className="space-y-6">
        {/* Header sezione con stato */}
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-3">
            {getSectionStatusIcon(sectionId)}
            <div>
              <p className="text-sm text-slate-500">{config.description}</p>
            </div>
          </div>
          {getSectionStatusBadge(sectionId)}
        </div>
        
        {/* Opzione "Non Applicabile" */}
        {config.canBeNotApplicable && isEditable && (
          <Card className={`border-2 ${isNotApplicable ? 'border-slate-400 bg-slate-100' : 'border-dashed border-slate-300'}`}>
            <CardContent className="p-4">
              {!isNotApplicable ? (
                <div className="flex items-start gap-3">
                  <Ban className="w-5 h-5 text-slate-500 mt-0.5" />
                  <div className="flex-1">
                    <p className="text-sm text-slate-700 mb-3">{config.notApplicableText}</p>
                    <Button 
                      variant="outline" 
                      size="sm"
                      onClick={() => markSectionNotApplicable(sectionId)}
                    >
                      Conferma: questa sezione non mi riguarda
                    </Button>
                  </div>
                </div>
              ) : (
                <div className="flex items-center justify-between">
                  <div className="flex items-center gap-2 text-slate-600">
                    <CheckCircle2 className="w-5 h-5 text-slate-500" />
                    <span className="font-medium">Hai indicato che questa sezione non ti riguarda</span>
                  </div>
                  <Button 
                    variant="ghost" 
                    size="sm"
                    onClick={() => unmarkSectionNotApplicable(sectionId)}
                  >
                    Modifica
                  </Button>
                </div>
              )}
            </CardContent>
          </Card>
        )}
        
        {/* Contenuto sezione (nascosto se non applicabile) */}
        {!isNotApplicable && (
          <div className="pt-2">
            {children}
          </div>
        )}
        
        {/* Pulsante Conferma */}
        {!isNotApplicable && isEditable && (
          <div className="flex justify-end pt-4 border-t">
            <Button 
              onClick={confirmAndProceed}
              className="bg-teal-600 hover:bg-teal-700"
              disabled={saving}
            >
              {saving ? (
                <>Salvataggio...</>
              ) : (
                <>
                  <Check className="w-4 h-4 mr-2" />
                  Conferma e Prosegui
                </>
              )}
            </Button>
          </div>
        )}
        
        {/* Se non applicabile, pulsante per procedere */}
        {isNotApplicable && isEditable && (
          <div className="flex justify-end pt-4">
            <Button 
              onClick={goToNextSection}
              className="bg-teal-600 hover:bg-teal-700"
            >
              Prosegui
              <ArrowRight className="w-4 h-4 ml-2" />
            </Button>
          </div>
        )}
      </div>
    );
  };
  
  // Sezione Dati Personali
  const renderPersonalData = () => (
    <SectionWrapper sectionId="datos_personales" config={SECTIONS_CONFIG.find(s => s.id === 'datos_personales')}>
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <Label>Nome <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.nombre || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'nombre', val)}
            disabled={!isEditable}
            placeholder="Il tuo nome"
          />
        </div>
        <div>
          <Label>Cognome <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.apellidos || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'apellidos', val)}
            disabled={!isEditable}
            placeholder="Il tuo cognome"
          />
        </div>
        <div>
          <Label>DNI/NIE <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.dni_nie || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'dni_nie', val)}
            disabled={!isEditable}
            placeholder="Es: X1234567A"
          />
        </div>
        <div>
          <Label>Data di Nascita <span className="text-red-500">*</span></Label>
          <Input 
            type="date"
            value={formData.datos_personales.fecha_nacimiento || ''}
            onChange={(e) => handleFieldChange('datos_personales', 'fecha_nacimiento', e.target.value)}
            disabled={!isEditable}
          />
        </div>
        <div className="md:col-span-2">
          <Label>Indirizzo di Residenza <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.direccion || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'direccion', val)}
            disabled={!isEditable}
            placeholder="Via, numero civico"
          />
        </div>
        <div>
          <Label>Comune <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.municipio || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'municipio', val)}
            disabled={!isEditable}
            placeholder="Es: Las Palmas"
          />
        </div>
        <div>
          <Label>Provincia <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.provincia || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'provincia', val)}
            disabled={!isEditable}
            placeholder="Es: Gran Canaria"
          />
        </div>
        <div>
          <Label>CAP <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.codigo_postal || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'codigo_postal', val)}
            disabled={!isEditable}
            placeholder="Es: 35001"
          />
        </div>
        <div>
          <Label>Paese</Label>
          <DebouncedInput 
            value={formData.datos_personales.pais || 'España'}
            onChange={(val) => handleFieldChange('datos_personales', 'pais', val)}
            disabled={!isEditable}
          />
        </div>
        <div>
          <Label>Telefono <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            value={formData.datos_personales.telefono || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'telefono', val)}
            disabled={!isEditable}
            placeholder="Es: +34 612 345 678"
          />
        </div>
        <div>
          <Label>Email <span className="text-red-500">*</span></Label>
          <DebouncedInput 
            type="email"
            value={formData.datos_personales.email || user?.email || ''}
            onChange={(val) => handleFieldChange('datos_personales', 'email', val)}
            disabled={!isEditable}
          />
        </div>
        <div>
          <Label>Stato Civile <span className="text-red-500">*</span></Label>
          <Select 
            value={formData.datos_personales.estado_civil || ''}
            onValueChange={(v) => handleFieldChange('datos_personales', 'estado_civil', v)}
            disabled={!isEditable}
          >
            <SelectTrigger>
              <SelectValue placeholder="Seleziona..." />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="soltero">Celibe/Nubile</SelectItem>
              <SelectItem value="casado">Coniugato/a</SelectItem>
              <SelectItem value="divorciado">Divorziato/a</SelectItem>
              <SelectItem value="viudo">Vedovo/a</SelectItem>
              <SelectItem value="pareja_hecho">Coppia di fatto</SelectItem>
            </SelectContent>
          </Select>
        </div>
        <label className="flex items-center gap-2 cursor-pointer md:col-span-2">
          <Checkbox
            checked={formData.datos_personales.residente_canarias || false}
            onCheckedChange={(c) => handleFieldChange('datos_personales', 'residente_canarias', c)}
            disabled={!isEditable}
          />
          <span>Sono residente nelle Isole Canarie</span>
        </label>
      </div>
    </SectionWrapper>
  );
  
  // Sezione Situazione Familiare
  const renderFamilyData = () => (
    <SectionWrapper sectionId="situacion_familiar" config={SECTIONS_CONFIG.find(s => s.id === 'situacion_familiar')}>
      <div className="space-y-6">
        <label className="flex items-center gap-2 cursor-pointer">
          <Checkbox
            checked={formData.situacion_familiar.tiene_conyuge || false}
            onCheckedChange={(c) => handleFieldChange('situacion_familiar', 'tiene_conyuge', c)}
            disabled={!isEditable}
          />
          <span className="font-medium">Ho un coniuge/partner registrato</span>
        </label>

        {formData.situacion_familiar.tiene_conyuge && (
          <Card className="bg-slate-50">
            <CardContent className="p-4 space-y-4">
              <h4 className="font-medium">Dati del Coniuge</h4>
              <div className="grid grid-cols-2 gap-4">
                <DebouncedInput 
                  placeholder="Nome"
                  value={formData.situacion_familiar.conyuge?.nombre || ''}
                  onChange={(val) => handleFieldChange('situacion_familiar', 'conyuge', {
                    ...formData.situacion_familiar.conyuge,
                    nombre: val
                  })}
                  disabled={!isEditable}
                />
                <DebouncedInput 
                  placeholder="Cognome"
                  value={formData.situacion_familiar.conyuge?.apellidos || ''}
                  onChange={(val) => handleFieldChange('situacion_familiar', 'conyuge', {
                    ...formData.situacion_familiar.conyuge,
                    apellidos: val
                  })}
                  disabled={!isEditable}
                />
                <DebouncedInput 
                  placeholder="DNI/NIE"
                  value={formData.situacion_familiar.conyuge?.dni_nie || ''}
                  onChange={(val) => handleFieldChange('situacion_familiar', 'conyuge', {
                    ...formData.situacion_familiar.conyuge,
                    dni_nie: val
                  })}
                  disabled={!isEditable}
                />
                <Input 
                  type="date"
                  placeholder="Data di nascita"
                  value={formData.situacion_familiar.conyuge?.fecha_nacimiento || ''}
                  onChange={(e) => handleFieldChange('situacion_familiar', 'conyuge', {
                    ...formData.situacion_familiar.conyuge,
                    fecha_nacimiento: e.target.value
                  })}
                  disabled={!isEditable}
                />
              </div>
            </CardContent>
          </Card>
        )}

        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label className="flex items-center gap-2 cursor-pointer">
            <Checkbox
              checked={formData.situacion_familiar.discapacidad_contribuyente || false}
              onCheckedChange={(c) => handleFieldChange('situacion_familiar', 'discapacidad_contribuyente', c)}
              disabled={!isEditable}
            />
            <span>Ho una disabilità riconosciuta</span>
          </label>
          <label className="flex items-center gap-2 cursor-pointer">
            <Checkbox
              checked={formData.situacion_familiar.familia_numerosa || false}
              onCheckedChange={(c) => handleFieldChange('situacion_familiar', 'familia_numerosa', c)}
              disabled={!isEditable}
            />
            <span>Famiglia numerosa</span>
          </label>
          <label className="flex items-center gap-2 cursor-pointer">
            <Checkbox
              checked={formData.situacion_familiar.familia_monoparental || false}
              onCheckedChange={(c) => handleFieldChange('situacion_familiar', 'familia_monoparental', c)}
              disabled={!isEditable}
            />
            <span>Famiglia monoparentale</span>
          </label>
        </div>

        <div>
          <Label>Note su variazioni familiari durante l'anno</Label>
          <DebouncedTextarea
            value={formData.situacion_familiar.variaciones_familiares || ''}
            onChange={(val) => handleFieldChange('situacion_familiar', 'variaciones_familiares', val)}
            placeholder="Es: matrimonio, separazione, nascita figli..."
            disabled={!isEditable}
          />
        </div>
      </div>
    </SectionWrapper>
  );
  
  // Sezione Redditi da Lavoro
  const renderEmploymentData = () => (
    <SectionWrapper sectionId="rentas_trabajo" config={SECTIONS_CONFIG.find(s => s.id === 'rentas_trabajo')}>
      <div className="space-y-6">
        <Card className="bg-blue-50 border-blue-200">
          <CardContent className="p-4">
            <p className="text-sm text-blue-800">
              Indica se hai percepito redditi da lavoro dipendente, pensione o disoccupazione durante l'anno fiscale {taxReturn.anno_fiscale}.
            </p>
          </CardContent>
        </Card>
        
        <label className="flex items-center gap-2 cursor-pointer">
          <Checkbox
            checked={formData.rentas_trabajo.tiene_rentas_trabajo || false}
            onCheckedChange={(c) => handleFieldChange('rentas_trabajo', 'tiene_rentas_trabajo', c)}
            disabled={!isEditable}
          />
          <span className="font-medium">Ho percepito redditi da lavoro dipendente</span>
        </label>

        {formData.rentas_trabajo.tiene_rentas_trabajo && (
          <>
            <div>
              <Label>Numero di datori di lavoro/pagatori</Label>
              <Input 
                type="number"
                min="0"
                value={formData.rentas_trabajo.numero_pagadores || 0}
                onChange={(e) => handleFieldChange('rentas_trabajo', 'numero_pagadores', parseInt(e.target.value))}
                disabled={!isEditable}
              />
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="space-y-2">
                <label className="flex items-center gap-2 cursor-pointer">
                  <Checkbox
                    checked={formData.rentas_trabajo.tiene_desempleo || false}
                    onCheckedChange={(c) => handleFieldChange('rentas_trabajo', 'tiene_desempleo', c)}
                    disabled={!isEditable}
                  />
                  <span>Ho percepito indennità di disoccupazione</span>
                </label>
                {formData.rentas_trabajo.tiene_desempleo && (
                  <div>
                    <Label>Importo annuo disoccupazione (€)</Label>
                    <Input 
                      type="number"
                      step="0.01"
                      value={formData.rentas_trabajo.importe_desempleo || 0}
                      onChange={(e) => handleFieldChange('rentas_trabajo', 'importe_desempleo', parseFloat(e.target.value))}
                      disabled={!isEditable}
                    />
                  </div>
                )}
              </div>

              <div className="space-y-2">
                <label className="flex items-center gap-2 cursor-pointer">
                  <Checkbox
                    checked={formData.rentas_trabajo.tiene_pension || false}
                    onCheckedChange={(c) => handleFieldChange('rentas_trabajo', 'tiene_pension', c)}
                    disabled={!isEditable}
                  />
                  <span>Ho percepito pensione</span>
                </label>
                {formData.rentas_trabajo.tiene_pension && (
                  <div>
                    <Label>Importo annuo pensione (€)</Label>
                    <Input 
                      type="number"
                      step="0.01"
                      value={formData.rentas_trabajo.importe_pension || 0}
                      onChange={(e) => handleFieldChange('rentas_trabajo', 'importe_pension', parseFloat(e.target.value))}
                      disabled={!isEditable}
                    />
                  </div>
                )}
              </div>
            </div>
          </>
        )}

        <div>
          <Label>Note aggiuntive</Label>
          <Textarea
            value={formData.rentas_trabajo.notas || ''}
            onChange={(e) => handleFieldChange('rentas_trabajo', 'notas', e.target.value)}
            placeholder="Ulteriori informazioni sui redditi da lavoro..."
            disabled={!isEditable}
          />
        </div>
      </div>
    </SectionWrapper>
  );
  
  // Sezione Lavoro Autonomo
  const renderSelfEmploymentData = () => (
    <SectionWrapper sectionId="autonomo" config={SECTIONS_CONFIG.find(s => s.id === 'autonomo')}>
      <div className="space-y-6">
        <label className="flex items-center gap-2 cursor-pointer">
          <Checkbox
            checked={formData.autonomo.es_autonomo || false}
            onCheckedChange={(c) => handleFieldChange('autonomo', 'es_autonomo', c)}
            disabled={!isEditable}
          />
          <span className="font-medium">Sono lavoratore autonomo / libero professionista</span>
        </label>

        {formData.autonomo.es_autonomo && (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <Label>Attività svolta</Label>
              <Input 
                value={formData.autonomo.actividad || ''}
