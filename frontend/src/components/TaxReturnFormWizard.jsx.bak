const API_URL = process.env.REACT_APP_BACKEND_URL;

// Helper per toast errori sicuro - evita errori con oggetti non serializzabili
const safeErrorToast = (error) => {
  try {
    if (typeof error === 'string') {
      toast.error(error);
    } else if (error?.message && typeof error.message === 'string') {
      toast.error(error.message);
    } else if (error?.detail && typeof error.detail === 'string') {
      toast.error(error.detail);
    } else {
      toast.error('Si è verificato un errore');
    }
  } catch (e) {
    console.error('Toast error:', e);
    toast.error('Si è verificato un errore');
  }
};

// Input ottimizzato che mantiene stato locale per scrittura fluida
const DebouncedInput = memo(({ value, onChange, onBlur, ...props }) => {
  const [localValue, setLocalValue] = useState(value || '');
  const inputRef = useRef(null);
  
  // Sincronizza con valore esterno solo quando cambia significativamente
  useEffect(() => {
    if (value !== undefined && value !== localValue && document.activeElement !== inputRef.current) {
      setLocalValue(value || '');
    }
  }, [value]);
  
  const handleChange = (e) => {
    setLocalValue(e.target.value);
  };
  
  const handleBlur = (e) => {
    // Aggiorna il form state solo quando l'utente esce dal campo
    if (onChange && localValue !== value) {
      onChange(localValue);
    }
    if (onBlur) onBlur(e);
  };
  
  return (
    <Input 
      ref={inputRef}
      value={localValue}
      onChange={handleChange}
      onBlur={handleBlur}
      {...props}
    />
  );
});

// Textarea ottimizzato
const DebouncedTextarea = memo(({ value, onChange, onBlur, ...props }) => {
  const [localValue, setLocalValue] = useState(value || '');
  const textareaRef = useRef(null);
  
  useEffect(() => {
    if (value !== undefined && value !== localValue && document.activeElement !== textareaRef.current) {
      setLocalValue(value || '');
    }
  }, [value]);
  
  const handleChange = (e) => {
    setLocalValue(e.target.value);
  };
  
  const handleBlur = (e) => {
    if (onChange && localValue !== value) {
      onChange(localValue);
    }
    if (onBlur) onBlur(e);
  };
  
  return (
    <Textarea 
      ref={textareaRef}
      value={localValue}
      onChange={handleChange}
      onBlur={handleBlur}
      {...props}
    />
  );
});

// Stati possibili per ogni sezione
const SECTION_STATUS = {
  NOT_STARTED: 'not_started',
  IN_PROGRESS: 'in_progress',
  NOT_APPLICABLE: 'not_applicable',
  COMPLETED: 'completed'
};

// Definizione sezioni con configurazione di validazione
