            disabled={!isEditable}
          />
        </div>
      </div>
    </SectionWrapper>
  );
  
  // Sezione Documenti
  const renderDocuments = () => {
    return (
      <div className="space-y-6">
        <Card className="bg-blue-50 border-blue-200">
          <CardContent className="p-4">
            <p className="text-sm text-blue-800">
              Carica i documenti a supporto della tua dichiarazione: certificati fiscali, buste paga, estratti conto, contratti, ecc.
            </p>
          </CardContent>
        </Card>
        
        {documents.length > 0 && (
          <div className="space-y-2">
            <h4 className="font-medium text-slate-900">Documenti caricati ({documents.length})</h4>
            {documents.map(doc => (
              <div key={doc.id} className="flex items-center justify-between p-3 bg-white border rounded-lg">
                <div className="flex items-center gap-3">
                  <FileText className="w-5 h-5 text-slate-400" />
                  <span className="text-sm font-medium">{doc.nombre}</span>
                </div>
                <Badge variant="outline">
                  {DOC_CATEGORIES.find(c => c.value === doc.categoria)?.label || doc.categoria}
                </Badge>
              </div>
            ))}
          </div>
        )}

        {isEditable && (
          <div className="flex gap-3">
            <Select value={docCategory} onValueChange={setDocCategory}>
              <SelectTrigger className="w-[200px]">
                <SelectValue placeholder="Categoria" />
              </SelectTrigger>
              <SelectContent>
                {DOC_CATEGORIES.map(cat => (
                  <SelectItem key={cat.value} value={cat.value}>{cat.label}</SelectItem>
                ))}
              </SelectContent>
            </Select>
            <Button
              variant="outline"
              onClick={() => {
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png';
                input.onchange = (e) => {
                  const file = e.target.files[0];
                  if (file) handleUploadDocument(file, docCategory, 'generale');
                };
                input.click();
              }}
              disabled={uploading}
            >
              <Upload className="w-4 h-4 mr-2" />
              {uploading ? 'Caricamento...' : 'Carica Documento'}
            </Button>
          </div>
        )}
        
        <div className="flex justify-end pt-4">
          <Button 
            onClick={goToNextSection}
            className="bg-teal-600 hover:bg-teal-700"
          >
            Prosegui al Riepilogo
            <ArrowRight className="w-4 h-4 ml-2" />
          </Button>
        </div>
      </div>
    );
  };
  
  // Sezione Riepilogo
  const renderSummary = () => {
    const incompleteSections = SECTIONS_CONFIG.filter(s => {
      if (s.isSpecial || s.skipValidation) return false;
      const status = sectionStatuses[s.id];
      return status !== SECTION_STATUS.COMPLETED && status !== SECTION_STATUS.NOT_APPLICABLE;
    });
    
    const isComplete = incompleteSections.length === 0;
    
    return (
      <div className="space-y-6">
        <div className="text-center mb-6">
          <div className={`w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 ${isComplete ? 'bg-green-100' : 'bg-amber-100'}`}>
            {isComplete ? (
              <CheckCircle2 className="w-8 h-8 text-green-600" />
            ) : (
              <AlertTriangle className="w-8 h-8 text-amber-600" />
            )}
          </div>
          <h3 className="text-xl font-semibold text-slate-900 mb-2">
            {isComplete ? 'Tutto completato!' : 'Alcune sezioni mancano'}
          </h3>
          <p className="text-slate-600">
            {isComplete 
              ? 'Hai completato tutte le sezioni. Puoi procedere alla firma.' 
              : 'Completa le sezioni mancanti prima di procedere.'
            }
          </p>
        </div>
        
        {/* Progress bar */}
        <div className="mb-6">
          <div className="flex justify-between text-sm text-slate-600 mb-2">
            <span>Progresso compilazione</span>
            <span>{calculateProgress()}%</span>
          </div>
          <Progress value={calculateProgress()} className="h-3" />
        </div>
        
        {/* Lista sezioni */}
        <div className="space-y-3">
          {SECTIONS_CONFIG.filter(s => !s.isSpecial).map((section, idx) => {
            const status = sectionStatuses[section.id];
            const isOk = status === SECTION_STATUS.COMPLETED || status === SECTION_STATUS.NOT_APPLICABLE;
            
            return (
              <div 
                key={section.id}
                className={`flex items-center justify-between p-4 rounded-lg border-2 cursor-pointer transition-colors ${getSectionStatusColor(section.id)}`}
                onClick={() => goToSection(SECTIONS_CONFIG.findIndex(s => s.id === section.id))}
              >
                <div className="flex items-center gap-3">
                  {getSectionStatusIcon(section.id)}
                  <div>
                    <p className="font-medium text-slate-900">{section.name}</p>
                    <p className="text-sm text-slate-500">{section.description}</p>
                  </div>
                </div>
                {getSectionStatusBadge(section.id)}
              </div>
            );
          })}
        </div>
        
        {/* Pulsante per procedere */}
        <div className="flex justify-end pt-4">
          <Button 
            onClick={goToNextSection}
            className="bg-teal-600 hover:bg-teal-700"
            disabled={!isComplete}
          >
            {isComplete ? (
              <>
                Procedi alla Firma
                <Pen className="w-4 h-4 ml-2" />
              </>
            ) : (
              <>
                <Lock className="w-4 h-4 mr-2" />
                Completa le sezioni mancanti
              </>
            )}
          </Button>
        </div>
      </div>
    );
  };
  
  // Sezione Autorizzazione e Firma
  const renderAuthorization = () => {
    const canSign = allSectionsComplete();
    
    return (
      <div className="space-y-6">
        {!canSign && (
          <Card className="bg-amber-50 border-amber-200">
            <CardContent className="p-4">
              <div className="flex items-center gap-3">
                <AlertTriangle className="w-5 h-5 text-amber-600" />
                <p className="text-sm text-amber-800">
                  Non puoi firmare la dichiarazione finché non hai completato tutte le sezioni. 
                  Torna al riepilogo per vedere le sezioni mancanti.
                </p>
              </div>
            </CardContent>
          </Card>
        )}
        
        {taxReturn.autorizacion?.signed_at ? (
          <Card className="bg-green-50 border-green-200">
            <CardContent className="p-6 text-center">
              <CheckCircle2 className="w-12 h-12 text-green-600 mx-auto mb-4" />
              <h3 className="text-lg font-semibold text-green-800 mb-2">
                Dichiarazione già firmata
              </h3>
              <p className="text-sm text-green-700">
                Firmata il {new Date(taxReturn.autorizacion.signed_at).toLocaleDateString('it-IT', {
                  day: 'numeric',
                  month: 'long',
                  year: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                })}
              </p>
            </CardContent>
          </Card>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <Pen className="w-5 h-5 text-teal-600" />
                Autorizzazione e Firma
              </CardTitle>
              <CardDescription>
                Leggi attentamente e firma per autorizzare Fiscal Tax Canarie
              </CardDescription>
            </CardHeader>
            <CardContent className="space-y-6">
              {/* Testo autorizzazione */}
              <div className="bg-slate-50 p-4 rounded-lg max-h-60 overflow-y-auto">
                <p className="text-sm text-slate-700 whitespace-pre-wrap">
                  {authText || `Con la presente, il/la sottoscritto/a autorizza Fiscal Tax Canarie SLP a:

1. Predisporre e presentare la dichiarazione dei redditi per l'anno fiscale ${taxReturn.anno_fiscale}

2. Accedere ai dati fiscali necessari presso l'Agenzia delle Entrate spagnola

3. Rappresentare il contribuente nei rapporti con l'Amministrazione Finanziaria relativamente alla presente dichiarazione

Il contribuente dichiara che tutti i dati forniti sono veritieri e completi, assumendosi la piena responsabilità delle informazioni dichiarate.`}
                </p>
              </div>
              
              {/* Avviso importante */}
              <div className="flex items-start gap-3 p-4 bg-yellow-50 rounded-lg">
                <AlertCircle className="w-5 h-5 text-yellow-600 flex-shrink-0 mt-0.5" />
                <p className="text-sm text-yellow-800">
                  Firmando questo documento, autorizzi Fiscal Tax Canarie SLP a predisporre e 
                  presentare la tua dichiarazione dei redditi per l'anno {taxReturn.anno_fiscale}. 
                  La firma è vincolante.
                </p>
              </div>

              {/* Checkbox consenso */}
              <div className="flex items-start gap-3 p-4 bg-teal-50 rounded-lg border-2 border-teal-200">
                <Checkbox
                  id="consent"
                  checked={consentAccepted}
                  onCheckedChange={setConsentAccepted}
                  disabled={!isEditable || !canSign}
                  className="mt-0.5"
                />
                <Label htmlFor="consent" className="font-medium cursor-pointer text-teal-900">
                  Dichiaro di aver letto e compreso quanto sopra. Confermo che tutti i dati inseriti sono veritieri 
                  e completi. Autorizzo Fiscal Tax Canarie SLP a procedere con la presentazione della mia dichiarazione.
                </Label>
              </div>

              {/* Canvas firma */}
              <div>
                <Label className="mb-2 block font-medium">
                  La tua firma <span className="text-red-500">*</span>
                </Label>
                <div className="border-2 border-dashed border-slate-300 rounded-lg bg-white">
                  <SignatureCanvas
                    ref={signatureRef}
                    canvasProps={{
                      className: 'w-full h-48',
                      style: { width: '100%', height: '180px' }
                    }}
                    backgroundColor="white"
                  />
                </div>
                <div className="flex justify-between items-center mt-2">
                  <p className="text-xs text-slate-500">Firma all'interno del riquadro usando il mouse o il dito</p>
                  <Button variant="outline" size="sm" onClick={clearSignature}>
                    <X className="w-4 h-4 mr-1" />
                    Cancella
                  </Button>
                </div>
              </div>

              {/* Pulsante firma */}
              <Button 
                onClick={handleSign}
                disabled={!consentAccepted || !isEditable || !canSign}
                className="w-full bg-teal-600 hover:bg-teal-700 py-6 text-lg"
                size="lg"
              >
                <Pen className="w-5 h-5 mr-2" />
                Firma e Invia Dichiarazione
              </Button>
            </CardContent>
          </Card>
        )}
      </div>
    );
  };
  
  // Render contenuto sezione corrente
  const renderSectionContent = () => {
    switch (currentSectionConfig?.id) {
      case 'intro': return renderIntro();
      case 'datos_personales': return renderPersonalData();
      case 'situacion_familiar': return renderFamilyData();
      case 'rentas_trabajo': return renderEmploymentData();
      case 'autonomo': return renderSelfEmploymentData();
      case 'inmuebles': return renderPropertiesData();
      case 'alquileres_cobrados': return renderRentalsReceivedData();
      case 'alquiler_pagado': return renderRentPaidData();
      case 'inversiones': return renderInvestmentsData();
      case 'criptomonedas': return renderCryptoData();
      case 'ganancias_patrimoniales': return renderCapitalGainsData();
      case 'deducciones': return renderDeductionsData();
      case 'deducciones_canarias': return renderCanaryDeductionsData();
      case 'documentos': return renderDocuments();
      case 'riepilogo': return renderSummary();
      case 'autorizacion': return renderAuthorization();
      default: return null;
    }
  };
  
  // === MAIN RENDER ===
  return (
    <div className="space-y-6" data-testid="tax-return-form-wizard">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-4">
          <Button variant="outline" onClick={onBack}>
            <ArrowLeft className="w-4 h-4 mr-2" />
            Indietro
          </Button>
          <div>
            <h1 className="text-xl font-bold text-slate-900">
              Dichiarazione dei Redditi {taxReturn.anno_fiscale}
            </h1>
            <div className="text-sm text-slate-500 flex items-center gap-2">
              <Badge variant="outline" className="capitalize">{taxReturn.stato}</Badge>
              <span>•</span>
              <span>{calculateProgress()}% completato</span>
            </div>
          </div>
        </div>
        {saving && (
          <Badge className="bg-amber-100 text-amber-700 animate-pulse">
            <Clock className="w-3 h-3 mr-1" />
            Salvataggio...
          </Badge>
        )}
      </div>

      {/* Progress Bar */}
      <div className="px-1">
        <Progress value={calculateProgress()} className="h-2" />
      </div>

      {/* Stepper Orizzontale */}
      <Card>
        <CardContent className="p-4">
          <div className="flex items-center gap-1 overflow-x-auto pb-2">
            {SECTIONS_CONFIG.map((section, idx) => {
              const isCurrent = idx === currentSection;
              const isCompleted = !section.isSpecial && (
                sectionStatuses[section.id] === SECTION_STATUS.COMPLETED || 
                sectionStatuses[section.id] === SECTION_STATUS.NOT_APPLICABLE
              );
              const isPast = idx < currentSection;
              
              return (
                <React.Fragment key={section.id}>
                  <button
                    onClick={() => {
                      if (idx <= currentSection || isCompleted) {
                        setCurrentSection(idx);
                      }
                    }}
                    disabled={idx > currentSection && !isCompleted}
                    className={`
                      flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors
                      ${isCurrent 
                        ? 'bg-teal-600 text-white' 
                        : isCompleted || isPast
                          ? 'bg-teal-100 text-teal-700 hover:bg-teal-200 cursor-pointer'
                          : 'bg-slate-100 text-slate-400 cursor-not-allowed'
                      }
                    `}
                  >
                    {isCompleted && !isCurrent ? (
                      <CheckCircle2 className="w-4 h-4" />
                    ) : (
                      <section.icon className="w-4 h-4" />
                    )}
                    <span className="hidden lg:inline">{section.name}</span>
                    <span className="lg:hidden">{idx + 1}</span>
                  </button>
                  {idx < SECTIONS_CONFIG.length - 1 && (
                    <div className={`w-4 h-0.5 ${isPast || isCompleted ? 'bg-teal-400' : 'bg-slate-200'}`} />
                  )}
                </React.Fragment>
              );
            })}
          </div>
        </CardContent>
      </Card>

      {/* Contenuto Sezione */}
      <Card>
        <CardHeader>
          <CardTitle className="flex items-center gap-2">
            {currentSectionConfig && <currentSectionConfig.icon className="w-5 h-5 text-teal-600" />}
            {currentSectionConfig?.name}
          </CardTitle>
        </CardHeader>
        <CardContent>
          {renderSectionContent()}
        </CardContent>
      </Card>

      {/* Navigazione */}
      <div className="flex justify-between">
        <Button 
          variant="outline"
          onClick={goToPreviousSection}
          disabled={currentSection === 0}
        >
          <ArrowLeft className="w-4 h-4 mr-2" />
          Precedente
        </Button>
        
        {/* Il pulsante Successivo è gestito all'interno di ogni sezione */}
        {(currentSectionConfig?.isSpecial && currentSectionConfig?.id !== 'intro' && currentSectionConfig?.id !== 'autorizacion' && currentSectionConfig?.id !== 'riepilogo' && currentSectionConfig?.id !== 'documentos') && (
          <Button 
            onClick={goToNextSection}
            disabled={currentSection === SECTIONS_CONFIG.length - 1}
            className="bg-teal-600 hover:bg-teal-700"
          >
            Successivo
            <ArrowRight className="w-4 h-4 ml-2" />
          </Button>
        )}
      </div>
    </div>
  );
};

export default TaxReturnFormWizard;
